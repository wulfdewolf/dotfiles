# --- Core ---
autoload -Uz compinit
compinit

# --- History ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory sharehistory hist_ignore_dups hist_reduce_blanks

# --- Navigation ---
setopt autocd
setopt pushdignoredups

# --- Globbing ---
setopt extendedglob
setopt nocaseglob

# --- Usability ---
setopt interactivecomments
setopt correct

# --- Prompt ---
autoload -Uz vcs_info
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats '  %b'
zstyle ':vcs_info:git:*' actionformats '  %b|%a'
setopt PROMPT_SUBST
PROMPT='%F{cyan}%~%f${vcs_info_msg_0_} > '
RPROMPT='%(?..%F{red}✗ %?%f)'

# --- Aliases  ---
export EDITOR=nvim
export PATH="$HOME/bin:$PATH"

# --- Enable vi mode ---
bindkey -v

# --- Lists ---
alias ls='eza --icons --color=always --group-directories-first'
alias ll='eza -lah --icons --git'
alias lt='eza --tree --level=2 --icons'
#
# --- Custom scripts ---
# open python project
project_widget() {
    BUFFER="$HOME/.local/bin/project.sh"
    CURSOR=${#BUFFER}
    zle accept-line
}
zle -N project_widget
bindkey -M viins '^P' project_widget

# find a file and open with default app
find_widget() {
    BUFFER="$HOME/.local/bin/find.sh"
    CURSOR=${#BUFFER}
    zle accept-line
}
zle -N find_widget
bindkey -M viins '^F' find_widget

# open a normal project
sessionizer_widget() {
    BUFFER="$HOME/.local/bin/tmux_sessionizer.sh"
    CURSOR=${#BUFFER}
    zle accept-line
}
zle -N sessionizer_widget
bindkey -M viins '^G' sessionizer_widget

# lazygit
lazygit_widget() {
    BUFFER="lazygit"
    CURSOR=${#BUFFER}
    zle accept-line
}
zle -N lazygit_widget
bindkey -M viins '^X' lazygit_widget

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
bindkey -M viins '^R' fzf-history-widget

